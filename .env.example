# Copy this file to `.env` and fill in the keys you need.

# Free — required for youtube-influencer-auditor only.
# Get one at console.cloud.google.com → enable "YouTube Data API v3".
YOUTUBE_API_KEY=

# Paid (~$0.20–0.60/run) — required for twitter / tiktok / instagram auditors.
# Get one at apify.com → Settings → API & Integrations. New accounts get $5 free credit.
APIFY_API_TOKEN=

# Optional — override the Apify actors if your account uses different ones.
# Defaults shown; leave blank to use them.
# APIFY_TWITTER_SCRAPER_ACTOR=apify~twitter-scraper
# APIFY_TWITTER_FOLLOWERS_ACTOR=apidojo~twitter-user-scraper
# APIFY_TIKTOK_SCRAPER_ACTOR=clockworks~tiktok-scraper
# APIFY_TIKTOK_COMMENTS_ACTOR=clockworks~tiktok-comments-scraper
# APIFY_IG_PROFILE_ACTOR=apify~instagram-profile-scraper
# APIFY_IG_COMMENTS_ACTOR=apify~instagram-comment-scraper
